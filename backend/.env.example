# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED — Server
# ──────────────────────────────────────────────────────────────────────────────
PORT=3000                              # REQUIRED  Render injects this automatically
NODE_ENV=development                    # REQUIRED  Set "production" on Render

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED — OneSignal
# ──────────────────────────────────────────────────────────────────────────────
ONESIGNAL_APP_ID=2d827c01-a2bd-47fb-a9f0-36744e68a51d
ONESIGNAL_REST_API_KEY=                # REQUIRED  OneSignal REST API key (Legacy)

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED — API Authentication
# ──────────────────────────────────────────────────────────────────────────────
BACKEND_API_KEY=                       # REQUIRED  Shared secret sent by Flutter app

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — CORS
# ──────────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*                          # OPTIONAL  Default: *

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Logging
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                        # OPTIONAL  Default: INFO
