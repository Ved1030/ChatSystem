{
  "rules": {
    ".read": false,
    ".write": false,
    "status": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid",
        ".validate": "newData.hasChildren(['isOnline', 'lastSeen']) && newData.child('isOnline').isBoolean() && newData.child('lastSeen').isNumber()"
      }
    },
    "typing": {
      "$roomId": {
        "$userId": {
          ".read": "auth != null",
          ".write": "auth.uid === $userId",
          ".validate": "newData.isBoolean()"
        }
      }
    }
  }
}
    }
  }
}
